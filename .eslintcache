rorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"91"},{"filePath":"102","messages":"103","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"104","messages":"105","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/home/voltagee/Desktop/todo/src/App.js",[],"/home/voltagee/Desktop/todo/src/components/header.jsx",[],["106","107"],"/home/voltagee/Desktop/todo/src/components/filter_menu.jsx",[],["108","109"],"/home/voltagee/Desktop/todo/src/utils/list_functions.js",[],["110","111"],"/home/voltagee/Desktop/todo/src/components/list_items.jsx",[],["112","113"],"/home/voltagee/Desktop/todo/src/components/file_upload.jsx",[],"/home/voltagee/Desktop/todo/src/components/calendar_view.jsx",[],["114","115"],"/home/voltagee/Desktop/todo/src/components/calendar_toggle.jsx",[],"/home/voltagee/Desktop/todo/src/index.js",[],"/home/voltagee/Desktop/todo/src/components/flagg.jsx",[],"/home/voltagee/Desktop/todo/src/components/text_field.jsx",[],"/home/voltagee/Desktop/todo/src/components/due_date.jsx",[],"/home/voltagee/Desktop/todo/src/components/todo_list.jsx",[],"/home/voltagee/Desktop/todo/src/components/details.jsx",[],"/home/voltagee/Desktop/todo/src/utils/emojis.js",[],"/home/voltagee/Desktop/todo/src/components/footer.jsx",[],"/home/voltagee/Desktop/todo/src/utils/local_storage.js",[],"/home/voltagee/Desktop/todo/src/reportWebVitals.js",[],["116","117"],"/home/voltagee/Desktop/todo/src/components/clear_data_btn.jsx",[],["118","119"],"/home/voltagee/Desktop/todo/src/base.js",[],"/home/voltagee/Desktop/todo/src/components/settings.jsx",["120"],"import React, { useState, useEffect } from 'react'\nimport ColorPicker from 'material-ui-color-picker'\nimport { saveToLocalStorage } from '../utils/local_storage';\n\n\nfunction Settings() {\n\n  const [bgColor, setBGColor] = useState(localStorage.getItem(\"bgColor\") || \"#c0e218\");\n  const [stickyTitle, setStickyTitle] = useState(localStorage.getItem(\"stickyTitle\") || \"QuickList\");\n\n\n  // componentDidMount\n  useEffect(() => {\n    document.getElementById(`app`).style.backgroundColor = bgColor;\n    document.getElementById(\"sticky-title\").textContent = stickyTitle;\n  }, []);\n\n  const handleBGColor = (color) => {\n    let element = document.getElementById(`app`);\n    setBGColor(color);\n    element.style.backgroundColor = color;\n    saveToLocalStorage(\"bgColor\", color);\n  }\n\n  const handleReset = () => {\n    let element = document.getElementById(`app`);\n    setBGColor(\"#c0e218\");\n    setStickyTitle(\"QuickList\");\n    element.style.backgroundColor = \"#c0e218\";\n    document.getElementById(\"sticky-title\").textContent = \"QuickList\"\n    saveToLocalStorage(\"bgColor\", \"#c0e218\");\n    saveToLocalStorage(\"stickyTitle\", \"QuickList\");\n  }\n\n  const handleTitleChange = (e) => {\n    setStickyTitle(e.target.value);\n    document.getElementById(\"sticky-title\").textContent = e.target.value\n    saveToLocalStorage(\"stickyTitle\", e.target.value);\n  }\n\n  return (\n    <div className=\"settings-container\">\n      <div className=\"settings-title-container\">\n        <h2 className=\"details-h2\">Sticky Title:</h2>\n        <input id=\"sticky-title-input\" type=\"text\" value={stickyTitle} onChange={handleTitleChange} />\n      </div>\n      <div className=\"color-picker-container\">\n        <h2 className=\"details-h2\">Sticky Color:</h2>\n        <ColorPicker\n          name='color'\n          defaultValue=\"#00000\"\n          value={bgColor}\n          onChange={handleBGColor}\n        />\n      </div>\n      <button id=\"default-settings-btn\" onClick={handleReset}>Default Settings</button>\n    </div>\n  );\n}\n\nexport default Settings;\n","/home/voltagee/Desktop/todo/src/components/todo_title.jsx",[],"/home/voltagee/Desktop/todo/src/components/settings_modal.jsx",[],"/home/voltagee/Desktop/todo/src/components/login_modal.jsx",[],{"ruleId":"121","replacedBy":"122"},{"ruleId":"123"