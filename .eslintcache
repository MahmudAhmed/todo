ome/voltagee/Desktop/todo/src/components/filter_menu.jsx",[],["133","134"],"/home/voltagee/Desktop/todo/src/utils/list_functions.js",[],["135","136"],"/home/voltagee/Desktop/todo/src/components/list_items.jsx",[],["137","138"],"/home/voltagee/Desktop/todo/src/components/file_upload.jsx",[],"/home/voltagee/Desktop/todo/src/components/calendar_view.jsx",[],["139","140"],"/home/voltagee/Desktop/todo/src/components/calendar_toggle.jsx",[],"/home/voltagee/Desktop/todo/src/index.js",[],"/home/voltagee/Desktop/todo/src/components/flagg.jsx",[],"/home/voltagee/Desktop/todo/src/components/text_field.jsx",[],"/home/voltagee/Desktop/todo/src/components/due_date.jsx",[],"/home/voltagee/Desktop/todo/src/components/todo_list.jsx",[],"/home/voltagee/Desktop/todo/src/components/details.jsx",[],"/home/voltagee/Desktop/todo/src/utils/emojis.js",[],"/home/voltagee/Desktop/todo/src/components/footer.jsx",[],"/home/voltagee/Desktop/todo/src/utils/local_storage.js",[],"/home/voltagee/Desktop/todo/src/reportWebVitals.js",[],["141","142"],"/home/voltagee/Desktop/todo/src/components/clear_data_btn.jsx",[],["143","144"],"/home/voltagee/Desktop/todo/src/base.js",[],"/home/voltagee/Desktop/todo/src/components/settings.jsx",["145"],"import React, { useState, useEffect } from 'react'\nimport ColorPicker from 'material-ui-color-picker'\nimport { saveToLocalStorage } from '../utils/local_storage';\n\n\nfunction Settings() {\n\n  const [bgColor, setBGColor] = useState(localStorage.getItem(\"bgColor\") || \"#c0e218\");\n  const [stickyTitle, setStickyTitle] = useState(localStorage.getItem(\"stickyTitle\") || \"QuickList\");\n\n\n  // componentDidMount\n  useEffect(() => {\n    document.getElementById(`app`).style.backgroundColor = bgColor;\n    document.getElementById(\"sticky-title\").textContent = stickyTitle;\n  }, []);\n\n  const handleBGColor = (color) => {\n    let element = document.getElementById(`app`);\n    setBGColor(color);\n    element.style.backgroundColor = color;\n    saveToLocalStorage(\"bgColor\", color);\n  }\n\n  const handleReset = () => {\n    let element = document.getElementById(`app`);\n    setBGColor(\"#c0e218\");\n    setStickyTitle(\"QuickList\");\n    element.style.backgroundColor = \"#c0e218\";\n    document.getElementById(\"sticky-title\").textContent = \"QuickList\"\n    saveToLocalStorage(\"bgColor\", \"#c0e218\");\n    saveToLocalStorage(\"stickyTitle\", \"QuickList\");\n  }\n\n  const handleTitleChange = (e) => {\n    setStickyTitle(e.target.value);\n    document.getElementById(\"sticky-title\").textContent = e.target.value\n    saveToLocalStorage(\"stickyTitle\", e.target.value);\n  }\n\n  return (\n    <div className=\"settings-container\">\n      <div className=\"settings-title-container\">\n        <h2 className=\"details-h2\">Sticky Title:</h2>\n        <input id=\"sticky-title-input\" type=\"text\" value={stickyTitle} onChange={handleTitleChange} />\n      </div>\n      <div className=\"color-picker-container\">\n        <h2 className=\"details-h2\">Sticky Color:</h2>\n        <ColorPicker\n          name='color'\n          defaultValue=\"#00000\"\n          value={bgColor}\n          onChange={handleBGColor}\n        />\n      </div>\n      <button id=\"default-settings-btn\" onClick={handleReset}>Default Settings</button>\n    </div>\n  );\n}\n\nexport default Settings;\n","/home/voltagee/Desktop/todo/src/components/todo_title.jsx",[],"/home/voltagee/Desktop/todo/src/components/settings_modal.jsx",[],"/home/voltagee/Desktop/todo/src/components/login_modal.jsx",[],"/home/voltagee/Desktop/Todo_challenge/todo/src/reportWebVitals.js",[],"/home/voltagee/Desktop/Todo_challenge/todo/src/components/todo_list.jsx",[],"/home/voltagee/Desktop/Todo_challenge/todo/src/components/settings_modal.jsx",[],"/home/voltagee/Desktop/Todo_challenge/todo/src/components/calendar_toggle.jsx",[],"/home/voltagee/Desktop/Todo_challenge/todo/src/components/file_upload.jsx",[],"/home/voltagee/Desktop/Todo_challenge/todo/src/components/login_modal.jsx",[],{"ruleId":"146","replacedBy":"147"},{"ruleId":"148","replacedBy":"149"},{"ruleId":"146","replacedBy":"150"},{"ruleId":"148","replacedBy":"151"},{"ruleId":"146","replacedBy":"152"},{"ruleId":"148","replacedBy":"153"},{"ruleId":"146","replacedBy":"154"},{"ruleId":"148","replacedBy":"155"},{"ruleId":"146","replacedBy":"156"},{"ruleId":"148","replacedBy":"157"},{"ruleId":"146","replacedBy":"158"},{"ruleId":"148","replacedBy":"159"},{"ruleId":"146","replacedBy":"160"},{"ruleId":"148","replacedBy":"161"},{"ruleId":"162","severity":1,"message":"163","line":16,"column":6,"nodeType":"164","endLine":16,"endColumn":8,"suggestions":"165"},"no-native-reassign",["166"],"no-negated-in-lhs",["167"],["166"],["167"],["166"],["167"],["166"],["167"],["166"],["167"],["166"],["167"],["166"],["167"],"react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'bgColor' and 'stickyTitle'. Either include them or remove the dependency array.","ArrayExpression",["168"],"no-global-assign","no-unsafe-negation",{"desc":"169","fix":"170"},"Update the dependencies array to be: [bgColor, stickyTitle]",{"range":"171","text":"172"},[567,569],"[bgColor, stickyTitle]"]